# app/mobile/.env.example
#
# Copy to `.env` and fill in the values that match your environment.
# Expo reads these via `expo-constants` at build time (see `app.json`).
#
# IMPORTANT: When testing on a physical Android device against a backend
# running on your laptop, replace `localhost` with the laptop's LAN IP.
# `localhost` from inside the device refers to the device itself, not
# your dev machine. See SETUP.md §Mobile network configuration.

# Backend API base URL.
# - Local dev (Android emulator):   http://10.0.2.2:8000
# - Local dev (iOS simulator):      http://localhost:8000
# - Local dev (physical device):    http://<your-LAN-IP>:8000   (e.g. http://192.168.1.42:8000)
# - Docker compose (host machine):  http://localhost:8000
# - Production:                     https://genipe.app
EXPO_PUBLIC_API_URL=http://localhost:8000

# Optional: image / media base URL (defaults to EXPO_PUBLIC_API_URL when unset).
# EXPO_PUBLIC_MEDIA_URL=http://localhost:8000

# Optional: enable verbose request logging in development.
EXPO_PUBLIC_DEBUG=false
