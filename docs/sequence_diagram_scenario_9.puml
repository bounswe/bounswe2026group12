@startuml
actor "Content Creator" as User
participant "Frontend (UI)" as UI
participant AuthService
participant RecipeController
participant Recipe
participant RecipeStructure
participant NotificationService

User -> UI: Navigate to own profile / feed
UI -> AuthService: verifySession(token)
activate AuthService
AuthService --> UI: session valid (userId)
deactivate AuthService

UI -> RecipeController: getOwnedRecipes(userId)
activate RecipeController
RecipeController -> Recipe: findByAuthorId(userId)
activate Recipe
Recipe --> RecipeController: list of owned recipes
deactivate Recipe
RecipeController --> UI: render recipe list
deactivate RecipeController

User -> UI: Click ... (three-dot menu) on a published recipe
UI --> User: Show context menu (Edit, Delete)

User -> UI: Click "Edit"
UI -> RecipeController: edit(recipeId, userId)
RecipeController -> AuthService: authorizeOwnership(userId, recipeId)
activate AuthService
AuthService --> RecipeController: authorization result
deactivate AuthService

alt User is NOT the owner
    RecipeController --> UI: 403 - You cannot edit this recipe
    UI --> User: Display error message

else User IS the owner
    RecipeController -> Recipe: edit()
    activate Recipe
    Recipe -> Recipe: isDraft = true
    Recipe --> RecipeController: ready to fetch structure
    deactivate Recipe

    RecipeController -> RecipeStructure: getStructure()
    activate RecipeStructure
    RecipeStructure --> RecipeController: parsedIngredients, parsedSteps, parsedTitle
    deactivate RecipeStructure

    RecipeController --> UI: render Edit Form pre-filled with structured fields
    UI --> User: Display editable form with current structured content

    User -> UI: Modify structured fields (e.g. fix ingredient, reorder step)
    UI -> RecipeController: updateField(recipeId, fieldName, newValue)
    RecipeController -> RecipeStructure: updateField(fieldName, newValue)
    activate RecipeStructure
    RecipeStructure -> RecipeStructure: persist change, set lastEditedBy and lastEditedAt
    RecipeStructure --> RecipeController: field updated successfully
    deactivate RecipeStructure
    RecipeController --> UI: Show live update confirmation

    alt User wants to save as draft
        User -> UI: Click "Save Draft"
        UI -> RecipeController: saveDraft(recipeId)
        RecipeController -> Recipe: saveDraft()
        activate Recipe
        Recipe -> Recipe: isDraft = true, updatedAt = now
        Recipe --> RecipeController: draft saved
        deactivate Recipe
        RecipeController --> UI: Draft saved confirmation
        UI --> User: Display success notification

    else User wants to republish
        User -> UI: Click "Update Post"
        UI -> RecipeController: republish(recipeId)
        RecipeController -> RecipeStructure: validate required fields
        activate RecipeStructure
        RecipeStructure --> RecipeController: validation result
        deactivate RecipeStructure

        alt Validation fails
            RecipeController --> UI: 422 - field required
            UI --> User: Highlight missing fields, prompt correction

        else Validation passes
            RecipeController -> Recipe: republish()
            activate Recipe
            Recipe -> Recipe: isPublished = true, isDraft = false, updatedAt = now
            Recipe --> RecipeController: republished successfully
            deactivate Recipe
            RecipeController -> NotificationService: triggerNotification(RECIPE_UPDATED, recipeId)
            activate NotificationService
            NotificationService --> RecipeController: notification queued
            deactivate NotificationService
            RecipeController --> UI: Return updated recipe data
            UI --> User: Recipe updated successfully
        end
    end
end
@enduml