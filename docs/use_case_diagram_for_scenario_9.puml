@startuml Scenario9_UseCase
skinparam backgroundColor #FAFAFA
skinparam ActorBorderColor #333333
skinparam ActorBackgroundColor #FAFAFA
skinparam UsecaseBorderColor #555555
skinparam UsecaseBackgroundColor #FFFDE7
skinparam ArrowColor #444444
skinparam PackageBorderColor #888888
skinparam PackageBackgroundColor #F5F5F5
skinparam NoteBackgroundColor #FFF9C4
skinparam NoteBorderColor #AAAAAA

left to right direction

title Scenario 9 — Content Creator: Edit Recipe After Sharing

' ── Actors ────────────────────────────────────────────────────────────────
actor "Guest" as Guest
actor "Authenticated\nUser\n(Content Creator)" as Creator

' ── Auth ──────────────────────────────────────────────────────────────────
usecase "Register" as UC_Register
usecase "Log In"   as UC_Login

' ── Navigation ────────────────────────────────────────────────────────────
usecase "View Own Recipe Posts\n(My Recipes / Profile)" as UC_ViewOwn
usecase "Open Three-Dot\nOptions Menu\n(own cards only)" as UC_ThreeDot

' ── Core Edit Use Case ────────────────────────────────────────────────────
usecase "Edit Recipe Post\n(pre-filled Edit Page)" as UC_EditRecipe

' ── Ingredient Entry ──────────────────────────────────────────────────────
usecase "Add Ingredient" as UC_AddIngredient
usecase "Select Ingredient\nfrom Dropdown\n(req 3.7.1, 3.7.3)" as UC_SelectIng
usecase "Propose New Ingredient\n(flagged for moderation)" as UC_AddNewIng
usecase "Enter Ingredient Amount\n(positive number, req 3.2.8)" as UC_EnterAmount
usecase "Select Unit\nfrom Dropdown\n(req 3.7.2)" as UC_SelectUnit
usecase "Propose New Unit\n(flagged for moderation)" as UC_AddNewUnit

' ── Description Edit ──────────────────────────────────────────────────────
usecase "Edit Free-Text\nDescription\n(req 3.2.10)" as UC_EditDescription

' ── Validation & Persistence ─────────────────────────────────────────────
usecase "Validate Required Fields\n(title, at least 1 ingredient, description)\n(req 3.2.11)" as UC_Validate
usecase "Save / Update Recipe\n(req 3.2.5)" as UC_Save
usecase "Receive Update\nConfirmation\n(req 3.2.6)" as UC_Confirm
usecase "Restore Draft\n(on failure / nav-away, req 4.4.3)" as UC_Draft
usecase "View Updated\nRecipe Detail\n(req 3.6.8)" as UC_ViewUpdated

' ── Moderation ───────────────────────────────────────────────────────────
usecase "Flag New Ingredient /\nUnit for Moderation\n(req 4.4.2)" as UC_Flag

' ── Guest reaches auth only ───────────────────────────────────────────────
Guest -- UC_Register
Guest -- UC_Login

' ── Creator: auth & navigation ────────────────────────────────────────────
Creator -- UC_Register
Creator -- UC_Login
Creator -- UC_ViewOwn

' ── Navigation chain: Profile -> ThreeDot -> EditPage ────────────────────
UC_ViewOwn ..> UC_ThreeDot    : <<include>>
UC_ThreeDot ..> UC_EditRecipe : <<include>>

' ── Edit Recipe optionally extends to add ingredient or edit description ──
UC_EditRecipe <.. UC_AddIngredient   : <<extend>>
UC_EditRecipe <.. UC_EditDescription : <<extend>>

' ── Adding an ingredient includes sub-steps ──────────────────────────────
UC_AddIngredient ..> UC_SelectIng   : <<include>>
UC_AddIngredient ..> UC_EnterAmount : <<include>>
UC_AddIngredient ..> UC_SelectUnit  : <<include>>

' ── Fallback when dropdown item not found ────────────────────────────────
UC_SelectIng  <.. UC_AddNewIng  : <<extend>>
UC_SelectUnit <.. UC_AddNewUnit : <<extend>>

' ── New entries trigger moderation flag ──────────────────────────────────
UC_AddNewIng  ..> UC_Flag : <<include>>
UC_AddNewUnit ..> UC_Flag : <<include>>

' ── Validation always included before save ───────────────────────────────
UC_EditRecipe ..> UC_Validate : <<include>>
UC_Validate   ..> UC_Save     : <<include>>
UC_Save       ..> UC_Confirm  : <<include>>

' ── On save failure: draft preserved ─────────────────────────────────────
UC_Save <.. UC_Draft : <<extend>>

' ── Post-update viewing ───────────────────────────────────────────────────
Creator -- UC_ViewUpdated

@enduml
